<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>
  <ItemGroup>
    <!-- Code coverage -->
    <PackageVersion Include="coverlet.collector" Version="10.0.0" />
    <!-- FastEndpoints -->
    <PackageVersion Include="FastEndpoints" Version="8.2.0-beta.15" />
    <PackageVersion Include="FastEndpoints.OpenApi" Version="8.2.0-beta.15" />
    <PackageVersion Include="FastEndpoints.OpenApi.Kiota" Version="8.2.0-beta.15" />
    <PackageVersion Include="FastEndpoints.Security" Version="8.2.0-beta.15" />
    <!-- Microsoft.AspNetCore -->
    <PackageVersion Include="Microsoft.AspNetCore.Authorization" Version="10.0.6" />
    <PackageVersion Include="Microsoft.AspNetCore.OpenApi" Version="10.0.6" />
    <!-- Microsoft.Extensions -->
    <PackageVersion Include="Microsoft.Extensions.Diagnostics.Testing" Version="10.5.0" />
    <PackageVersion Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.6" />
    <!-- Microsoft.Identity -->
    <PackageVersion Include="Microsoft.Identity.Web" Version="4.8.0" />
    <!-- Scalar -->
    <PackageVersion Include="Scalar.AspNetCore" Version="2.14.1" />
    <!-- Testing -->
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="18.4.0" />
    <!-- xunit -->
    <PackageVersion Include="xunit" Version="2.9.3" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="3.1.5" />
  </ItemGroup>
</Project>