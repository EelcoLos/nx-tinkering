{
  "version": "0.2.0",
  "configurations": [
    {
      // Use IntelliSense to find out which attributes exist for C# debugging
      // Use hover for the description of the existing attributes
      // For further information visit https://github.com/dotnet/vscode-csharp/blob/main/debugger-launchjson.md.
      "name": "dotnet-fe-auth",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      // If you have changed target frameworks, make sure to update the program path.
      "program": "${workspaceFolder}/dist/apps/dotnet-fe-auth/net9.0/dotnet-fe-auth.dll",
      "args": [],
      "cwd": "${workspaceFolder}/apps/dotnet-fe-auth",
      "stopAtEntry": false,
      // Enable launching a web browser when ASP.NET Core starts. For more information: https://aka.ms/VSCode-CS-LaunchJson-WebBrowser
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      }
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach"
    },
    {
      "name": "A2A Demo: Identity",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build a2a identity",
      "program": "${workspaceFolder}/dist/apps/a2a-docker-demo/identity/net10.0/identity.dll",
      "args": [],
      "cwd": "${workspaceFolder}/apps/a2a-docker-demo/identity",
      "stopAtEntry": false,
      "envFile": "${workspaceFolder}/apps/a2a-docker-demo/.env",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5050",
        "IDENTITY_SERVICE_URL": "http://localhost:5050",
        "DISCOVERY_SERVICE_URL": "http://localhost:5051",
        "OIDC_TOKEN_ENDPOINT": "http://localhost:8081/realms/a2a-local/protocol/openid-connect/token",
        "OIDC_INTROSPECTION_ENDPOINT": "http://localhost:8081/realms/a2a-local/protocol/openid-connect/token/introspect",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    },
