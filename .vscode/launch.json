  "compounds": [
    {
      "name": "A2A Demo: Services Only",
      "configurations": [
        "A2A Demo: Identity",
        "A2A Demo: Discovery",
        "A2A Demo: Classifier",
        "A2A Demo: Assessor",
        "A2A Demo: Router",
        "A2A Demo: Handler",
        "A2A Demo: API Backend"
      ],
      "stopAll": true
    },
    {
      "name": "A2A Demo: Full Triage Stack",
      "configurations": [
        "A2A Demo: Identity",
        "A2A Demo: Discovery",
        "A2A Demo: Classifier",
        "A2A Demo: Assessor",
        "A2A Demo: Router",
