# A2A Triage Demo - Environment Configuration
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ============ Service URLs ============
IDENTITY_SERVICE_URL=http://identity:5050
DISCOVERY_SERVICE_URL=http://discovery:5051
CLASSIFIER_SERVICE_URL=http://classifier:5052
ASSESSOR_SERVICE_URL=http://assessor:5053
ROUTER_SERVICE_URL=http://router:5054
HANDLER_SERVICE_URL=http://handler:5055
API_BACKEND_SERVICE_URL=http://api-backend:5056

# ============ JWT Configuration ============
JWT_SECRET_KEY=your-secret-key-min-32-characters-change-this

# ============ OIDC Configuration (Keycloak Local) ============
OIDC_ENABLED=true
OIDC_TOKEN_ENDPOINT=http://keycloak:8080/realms/a2a-local/protocol/openid-connect/token
OIDC_INTROSPECTION_ENDPOINT=http://keycloak:8080/realms/a2a-local/protocol/openid-connect/token/introspect
OIDC_USER_CLIENT_ID=website-client
OIDC_USER_CLIENT_SECRET=website-client-secret
OIDC_IDENTITY_CLIENT_ID=identity-facade
OIDC_IDENTITY_CLIENT_SECRET=identity-facade-secret

# Per-agent app registrations (client credentials)
OIDC_DISCOVERY_CLIENT_ID=discovery-agent
OIDC_DISCOVERY_CLIENT_SECRET=discovery-agent-secret
OIDC_CLASSIFIER_CLIENT_ID=classifier-agent
OIDC_CLASSIFIER_CLIENT_SECRET=classifier-agent-secret
OIDC_ASSESSOR_CLIENT_ID=assessor-agent
OIDC_ASSESSOR_CLIENT_SECRET=assessor-agent-secret
OIDC_ROUTER_CLIENT_ID=router-agent
OIDC_ROUTER_CLIENT_SECRET=router-agent-secret
OIDC_HANDLER_CLIENT_ID=handler-agent
OIDC_HANDLER_CLIENT_SECRET=handler-agent-secret
OIDC_API_BACKEND_CLIENT_ID=api-backend-agent
OIDC_API_BACKEND_CLIENT_SECRET=api-backend-agent-secret

# ============ OpenTelemetry ============
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAMESPACE=a2a-docker-demo

# ============ Agent Identities ============
DISCOVERY_AGENT_ID=discovery-agent
CLASSIFIER_AGENT_ID=classifier-agent
ASSESSOR_AGENT_ID=assessor-agent
ROUTER_AGENT_ID=router-agent
HANDLER_AGENT_ID=handler-agent
API_BACKEND_AGENT_ID=api-backend-agent

# ============ Demo User Credentials ============
DEMO_USER_USERNAME=admin
DEMO_USER_PASSWORD=demo123
DEMO_USER2_USERNAME=user
DEMO_USER2_PASSWORD=user456

# ============ Website & API ============
WEBSITE_PORT=3000
API_BACKEND_PORT=5056

# ============ Logging ============
LOG_LEVEL=Information
