# A2A Triage Demo - Environment Configuration
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ============ Service URLs ============
IDENTITY_SERVICE_URL=http://identity:5050
DISCOVERY_SERVICE_URL=http://discovery:5051
CLASSIFIER_SERVICE_URL=http://classifier:5052
ASSESSOR_SERVICE_URL=http://assessor:5053
ROUTER_SERVICE_URL=http://router:5054
HANDLER_SERVICE_URL=http://handler:5055
API_BACKEND_URL=http://api:5056

# ============ JWT Configuration ============
# Generate a strong secret key (min 32 characters)
JWT_SECRET_KEY=your-secret-key-min-32-characters-change-this

# ============ Agent Credentials (Specialist Services) ============
# These are used by services to authenticate with the Identity Service
CLASSIFIER_AGENT_ID=classifier_agent
CLASSIFIER_AGENT_SECRET=classifier-secret-change-this

ASSESSOR_AGENT_ID=assessor_agent
ASSESSOR_AGENT_SECRET=assessor-secret-change-this

ROUTER_AGENT_ID=router_agent
ROUTER_AGENT_SECRET=router-secret-change-this

HANDLER_AGENT_ID=handler_agent
HANDLER_AGENT_SECRET=handler-secret-change-this

# ============ Demo User Credentials ============
# Used for interactive login on the website
DEMO_USER_USERNAME=admin
DEMO_USER_PASSWORD=demo123

DEMO_USER2_USERNAME=user
DEMO_USER2_PASSWORD=user456

# ============ Database ============
# For Docker, use /data/users.db (with volume mapping)
# For local development, use relative path
DATABASE_URL=sqlite:///data/users.db

# ============ Website & API ============
WEBSITE_PORT=3000
API_BACKEND_PORT=5056

# ============ Logging ============
LOG_LEVEL=Information
