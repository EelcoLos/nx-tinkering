    {
      "type": "text",
      "title": "A2A Tool Calling Traces",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "content": "This dashboard is preconfigured for semconv-aligned GenAI spans emitted by the A2A demo.\n\nGrafana's Tempo search API returns matched spans inside a nested payload while the visible table row stays rooted at the full trace. To keep tool calls discoverable, this dashboard splits recent traces by tool and remaps the displayed operation name to the matched semantic span for each panel.\n\nEach correlation_id is a clickable deep link into Grafana Explore for the full trace.",
        "mode": "markdown"
      }
    },
    {
      "type": "table",
      "title": "A2A skill classifier",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceqlSearch",
          "limit": 50,
          "query": "{ span.gen_ai.operation.name = \"execute_tool\" && span.gen_ai.tool.name = \"classifier\" } with (most_recent=true)",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "nested": true,
              "traceName": true,
              "traceService": true
            },
            "indexByName": {
              "traceID": 0,
              "startTime": 1,
              "traceDuration": 2
            },
            "renameByName": {
              "traceID": "correlation_id",
              "startTime": "trace_start",
              "traceDuration": "trace_duration_ms"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "columnFilter": true,
        "enablePagination": true
      }
    },
