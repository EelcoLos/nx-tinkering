  "panels": [
    {
      "type": "text",
      "title": "A2A Service Overview",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "content": "Top-level health view for the A2A demo services. Health is probed through Prometheus blackbox checks against each service's FastEndpoints /health route.",
        "mode": "markdown"
      }
    },
    {
      "type": "stat",
      "title": "Identity",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(probe_success{job=\"a2a-health\",service=\"identity\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "max": 1,
          "min": 0
        },
        "overrides": []
      }
    },
